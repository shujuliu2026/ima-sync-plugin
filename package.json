{
  "name": "ima-sync-plugin",
  "version": "1.5.91",
  "description": "Obsidian to Tencent IMA knowledge base sync plugin",
  "private": false,
  "scripts": {
    "bundle": "node scripts/bundle.mjs",
    "sync-versions": "node scripts/sync-versions.mjs",
    "selftest": "node scripts/selftest.mjs",
    "selftest:quick": "node scripts/selftest.mjs --quick",
    "stresstest": "node scripts/stresstest.mjs",
    "stresstest:quick": "node scripts/stresstest.mjs --quick",
    "pregate": "npm run selftest && npm run stresstest",
    "pregate:quick": "npm run selftest:quick && npm run stresstest:quick",
    "install-plugin": "node scripts/install.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "linkedom": "^0.18.13"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shujuliu2026/ima-sync-plugin.git"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "ima",
    "tencent-ima",
    "knowledge-base"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "defuddle": "^0.19.1"
  }
}
